# =========================================================
# MASTER OBSIDIAN .GITIGNORE
# Suitable for: GitHub, Bitbucket, Mobile, Desktop, Work
# =========================================================

# --- SECTION 1: The "Anti-Conflict" Zone ---
# These files change constantly. Syncing them causes merge conflicts.
# NEVER un-ignore these.
.obsidian/workspace*
.obsidian/cache/
.obsidian/backups/
.obsidian/temp.json
.obsidian/daily_notes.json

# --- SECTION 2: AI & Large Data Protection ---
# Vector DBs and AI indexes are too large/volatile for Git sync.
.smart-connections/
.pro/
copilot-index-*.json

# --- SECTION 3: System & OS Junk ---
.DS_Store
Thumbs.db
desktop.ini
.Trash-1000/
.trash/
*.tmp
*.bak
*.log

# --- SECTION 4: Developer/Project Files ---
# If you keep code snippets or projects inside your vault
.git/
.idea/
.vscode/
node_modules/
__pycache__/
*.ipynb_checkpoints/

# --- SECTION 5: Configuration (Allowed) ---
# We deliberately DO NOT ignore these, so your settings/plugins sync.
# .obsidian/app.json
# .obsidian/appearance.json
# .obsidian/community-plugins.json
# .obsidian/plugins/
# .obsidian/snippets/

# --- SECTION 6: Emergency Fixes ---
# Handle occasional conflict files if they get generated
*conflict*
*.sync-conflict-*
# --- MCP Plugin: bearer token must not be committed ---
# Port assignments are documented in _Meta/00_SOPs/MCP Pro Server Setup.md
.obsidian/plugins/obsidian-mcp-pro-plugin/data.json
